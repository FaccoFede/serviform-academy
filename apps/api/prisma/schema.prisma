generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── UTENTI ───────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  firstName    String?
  lastName     String?
  passwordHash String?
  role         Role      @default(USER)
  avatarUrl    String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  progress       UserProgress[]
  certificates   Certificate[]
  membership     CompanyMembership?
  courseOverrides UserCourseAssignment[]
  unitFeedback   UnitFeedback[]
  courseFeedback CourseFeedback[]
}

enum Role {
  USER
  ADMIN
  TEAM_ADMIN
}

// ─── SOFTWARE ─────────────────────────────────────────────────────────────────

model Software {
  id         String    @id @default(uuid())
  name       String
  slug       String    @unique
  tagline    String?
  color      String?
  lightColor String?
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  courses           Course[]
  companyInterests  CompanyInterest[]
}

// ─── CORSI ────────────────────────────────────────────────────────────────────

model Course {
  id          String      @id @default(uuid())
  title       String
  slug        String      @unique
  description String?
  level       String?
  duration    String?
  objective   String?     // obiettivo pratico del corso (doc §9)

  // Visibilità base: stato di pubblicazione del corso (indipendente dalle assegnazioni)
  // HIDDEN         → non compare mai nel catalogo
  // VISIBLE_LOCKED → visibile ma non fruibile senza assegnazione
  // PUBLISHED      → visibile e fruibile se assegnato
  publishState CoursePublishState @default(PUBLISHED)

  // DEPRECATO: mantenuto per retrocompatibilità durante la migrazione.
  // Non usare come driver di accesso. Usare CoursePublishState + assegnazioni.
  available   Boolean   @default(true)

  softwareId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  software            Software               @relation(fields: [softwareId], references: [id])
  units               Unit[]
  certificates        Certificate[]
  companyAssignments  CompanyCourseAssignment[]
  userAssignments     UserCourseAssignment[]
  courseFeedback      CourseFeedback[]
}

enum CoursePublishState {
  HIDDEN          // non compare nel catalogo
  VISIBLE_LOCKED  // compare ma bloccato (visibile, non fruibile)
  PUBLISHED       // visibile e fruibile se assegnato
}

// ─── UNITÀ ────────────────────────────────────────────────────────────────────

model Unit {
  id        String   @id @default(uuid())
  title     String
  slug      String
  order     Int
  subtitle  String?
  duration  String?
  unitType  UnitType @default(LESSON)
  content   String?  @db.Text
  videoUrl  String?  // URL video corso (embed protetto, no YouTube diretto)
  courseId  String

  course     Course          @relation(fields: [courseId], references: [id])
  guide      GuideReference?
  exercises  Exercise[]
  progress   UserProgress[]
  feedback   UnitFeedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@unique([courseId, slug])
}

enum UnitType {
  OVERVIEW
  LESSON
  EXERCISE
}

// ─── CONTENUTI SUPPORTO ───────────────────────────────────────────────────────

model GuideReference {
  id        String @id @default(uuid())
  zendeskId String
  title     String
  url       String
  unitId    String @unique
  unit      Unit   @relation(fields: [unitId], references: [id])
}

model Exercise {
  id          String   @id @default(uuid())
  title       String
  description String?
  htmlUrl     String?
  evdUrl      String?
  order       Int      @default(0)
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id])
  createdAt   DateTime @default(now())
}

// ─── AZIENDE (dominio B2B) ────────────────────────────────────────────────────

model Company {
  id                  String    @id @default(uuid())
  name                String
  slug                String    @unique
  contractType        String?   // es. "Standard", "Enterprise", "Trial"
  assistanceExpiresAt DateTime? // scadenza contratto assistenza
  notes               String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  members          CompanyMembership[]
  courseAssignments CompanyCourseAssignment[]
  interests        CompanyInterest[]
}

// Punti di interesse dell'azienda (quali software usa)
model CompanyInterest {
  id         String   @id @default(uuid())
  companyId  String
  softwareId String
  company    Company  @relation(fields: [companyId], references: [id])
  software   Software @relation(fields: [softwareId], references: [id])

  @@unique([companyId, softwareId])
}

// Appartenenza utente a un'azienda
model CompanyMembership {
  id        String   @id @default(uuid())
  userId    String   @unique  // un utente appartiene a una sola azienda
  companyId String
  role      String   @default("member") // "member" | "admin"
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
}

// ─── ASSEGNAZIONI CORSI ───────────────────────────────────────────────────────

// Assegnazione corso a livello azienda
model CompanyCourseAssignment {
  id           String           @id @default(uuid())
  companyId    String
  courseId     String
  accessType   CourseAccessType @default(ACTIVE)
  startsAt     DateTime         @default(now())
  expiresAt    DateTime?        // null = accesso illimitato (∞)
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  createdBy    String?          // userId admin che ha creato l'assegnazione

  company Company @relation(fields: [companyId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])

  @@unique([companyId, courseId])
  @@index([companyId])
  @@index([expiresAt])
}

// Override assegnazione a livello singolo utente
// Prevale sulla policy aziendale (regola più specifica vince)
model UserCourseAssignment {
  id           String           @id @default(uuid())
  userId       String
  courseId     String
  accessType   CourseAccessType @default(ACTIVE)
  startsAt     DateTime         @default(now())
  expiresAt    DateTime?        // null = accesso illimitato (∞)
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  createdBy    String?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([expiresAt])
}

enum CourseAccessType {
  ACTIVE   // accesso pieno
  LOCKED   // visibile ma bloccato
  HIDDEN   // non visibile
}

// ─── PROGRESSO ────────────────────────────────────────────────────────────────

model UserProgress {
  id          String    @id @default(uuid())
  userId      String
  unitId      String
  completed   Boolean   @default(false)
  completedAt DateTime?
  viewedAt    DateTime? // ultimo accesso all'unità (per "continua da dove eri")

  user User @relation(fields: [userId], references: [id])
  unit Unit @relation(fields: [unitId], references: [id])

  @@unique([userId, unitId])
  @@index([userId, completed])
}

// ─── FEEDBACK ────────────────────────────────────────────────────────────────

// Feedback per singola unità (utile / non utile)
model UnitFeedback {
  id        String   @id @default(uuid())
  userId    String
  unitId    String
  useful    Boolean
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  unit Unit @relation(fields: [unitId], references: [id])

  @@unique([userId, unitId])
}

// Feedback a fine corso (rating 1-5 stelle)
model CourseFeedback {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

// ─── CERTIFICATI ─────────────────────────────────────────────────────────────

model Certificate {
  id       String   @id @default(uuid())
  userId   String
  courseId String
  issuedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

// ─── ANNUNCI ─────────────────────────────────────────────────────────────────

model Announcement {
  id          String    @id @default(uuid())
  title       String
  body        String    @db.Text
  type        AnnouncementType @default(NEWS)
  published   Boolean   @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
}

enum AnnouncementType {
  NEWS        // novità generali
  NEW_COURSE  // nuovo corso disponibile
  WEBINAR     // webinar/evento
  MAINTENANCE // manutenzione
}

// ─── IMPORT CSV ───────────────────────────────────────────────────────────────

model CsvImportJob {
  id         String          @id @default(uuid())
  type       CsvImportType
  status     CsvImportStatus @default(PENDING)
  filename   String
  totalRows  Int             @default(0)
  imported   Int             @default(0)
  failed     Int             @default(0)
  errors     Json?           // array di { row, message }
  createdAt  DateTime        @default(now())
  completedAt DateTime?
  createdBy  String?
}

enum CsvImportType {
  COMPANIES
  USERS
}

enum CsvImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── VIDEO PILL (isolato, fuori scope attivo) ─────────────────────────────────
// Mantenuto per retrocompatibilità con i dati esistenti.
// Non esposto in navigazione né nei moduli attivi.

model VideoPill {
  id          String   @id @default(uuid())
  title       String
  description String?
  youtubeId   String   @unique
  softwareId  String
  createdAt   DateTime @default(now())
}

// ─── PRICING (isolato, fuori scope) ───────────────────────────────────────────
// Mantenuto per non perdere dati storici. Non esposto nei moduli attivi.

model PricingPackage {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  price       String?
  priceNote   String?
  features    String[] @default([])
  highlighted Boolean  @default(false)
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── EVENTI (isolato, fuori scope attivo) ────────────────────────────────────

model Event {
  id              String    @id @default(uuid())
  title           String
  description     String?   @db.Text
  eventType       EventType @default(WEBINAR)
  date            DateTime
  endDate         DateTime?
  location        String?
  maxSeats        Int?
  registrationUrl String?
  recordingUrl    String?
  published       Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum EventType {
  WORKSHOP
  WEBINAR
  LIVE_SESSION
}
