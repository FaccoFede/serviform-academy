generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  passwordHash String?
  role         Role      @default(USER)
  avatarUrl    String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  progress     UserProgress[]
  certificates Certificate[]
}

enum Role {
  USER
  ADMIN
  TEAM_ADMIN
}

model Software {
  id         String    @id @default(uuid())
  name       String
  slug       String    @unique
  tagline    String?
  color      String?
  lightColor String?
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  courses    Course[]
  videos     VideoPill[]
}

model Course {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  description String?
  level       String?
  duration    String?
  available   Boolean   @default(true)
  softwareId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  software     Software      @relation(fields: [softwareId], references: [id])
  units        Unit[]
  certificates Certificate[]
}

model Unit {
  id            String    @id @default(uuid())
  title         String
  slug          String
  order         Int
  subtitle      String?
  duration      String?
  unitType      UnitType  @default(LESSON)
  content       String?   @db.Text
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id])
  guide          GuideReference?
  exercises      Exercise[]
  progress       UserProgress[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  @@unique([courseId, slug])
}

enum UnitType {
  OVERVIEW
  LESSON
  EXERCISE
}

model GuideReference {
  id        String @id @default(uuid())
  zendeskId String
  title     String
  url       String
  unitId    String @unique
  unit      Unit   @relation(fields: [unitId], references: [id])
}

model Exercise {
  id          String   @id @default(uuid())
  title       String
  description String?
  htmlUrl     String?
  evdUrl      String?
  order       Int      @default(0)
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id])
  createdAt   DateTime @default(now())
}

model VideoPill {
  id          String   @id @default(uuid())
  title       String
  description String?
  youtubeId   String   @unique
  softwareId  String
  software    Software @relation(fields: [softwareId], references: [id])
  createdAt   DateTime @default(now())
}

model Certificate {
  id       String   @id @default(uuid())
  userId   String
  courseId  String
  issuedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])
  @@unique([userId, courseId])
}

model UserProgress {
  id          String    @id @default(uuid())
  userId      String
  unitId      String
  completed   Boolean   @default(false)
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id])
  unit        Unit      @relation(fields: [unitId], references: [id])
  @@unique([userId, unitId])
  @@index([userId, completed])
}

model Event {
  id              String    @id @default(uuid())
  title           String
  description     String?   @db.Text
  eventType       EventType @default(WEBINAR)
  date            DateTime
  endDate         DateTime?
  location        String?
  maxSeats        Int?
  registrationUrl String?
  recordingUrl    String?
  published       Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum EventType {
  WORKSHOP
  WEBINAR
  LIVE_SESSION
}

model PricingPackage {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  price       String?
  priceNote   String?
  features    String[] @default([])
  highlighted Boolean  @default(false)
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
