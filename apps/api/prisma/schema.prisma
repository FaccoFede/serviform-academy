generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  firstName    String?
  lastName     String?
  passwordHash String?
  role         Role      @default(USER)
  avatarUrl    String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  progress     UserProgress[]
  certificates Certificate[]
  membership   CompanyMembership?
  userAssignments UserCourseAssignment[]
}

enum Role {
  USER
  ADMIN
  TEAM_ADMIN
}

model Company {
  id                  String    @id @default(uuid())
  name                String
  slug                String    @unique
  contractType        String?
  assistanceExpiresAt DateTime?
  notes               String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
  members             CompanyMembership[]
  interests           CompanyInterest[]
  courseAssignments   CompanyCourseAssignment[]
}

model CompanyMembership {
  id        String   @id @default(uuid())
  userId    String   @unique
  companyId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])
}

model CompanyInterest {
  id         String   @id @default(uuid())
  companyId  String
  softwareId String
  company    Company  @relation(fields: [companyId], references: [id])
  software   Software @relation(fields: [softwareId], references: [id])
  @@unique([companyId, softwareId])
}

model CompanyCourseAssignment {
  id         String     @id @default(uuid())
  companyId  String
  courseId   String
  accessType String  @default("ACTIVE")
  startsAt   DateTime   @default(now())
  expiresAt  DateTime?
  notes      String?
  createdBy  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  company    Company    @relation(fields: [companyId], references: [id])
  course     Course     @relation(fields: [courseId], references: [id])
  @@unique([companyId, courseId])
}

model UserCourseAssignment {
  id         String     @id @default(uuid())
  userId     String
  courseId   String
  accessType String  @default("ACTIVE")
  startsAt   DateTime   @default(now())
  expiresAt  DateTime?
  notes      String?
  createdBy  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id])
  course     Course     @relation(fields: [courseId], references: [id])
  @@unique([userId, courseId])
}

enum AccessType {
  ACTIVE
  LOCKED
  HIDDEN
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  body        String   @db.Text
  type        AnnouncementType @default(NEWS)
  published   Boolean  @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum AnnouncementType {
  NEWS
  NEW_COURSE
  WEBINAR
  MAINTENANCE
}

model Software {
  id         String    @id @default(uuid())
  name       String
  slug       String    @unique
  tagline    String?
  color      String?
  lightColor String?
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  courses    Course[]
  interests  CompanyInterest[]
  videos     VideoPill[]
}

model Course {
  id           String    @id @default(uuid())
  title        String
  slug         String    @unique
  description  String?
  objective    String?
  level        String?
  duration     String?
  available    Boolean   @default(true)
  publishState PublishState @default(PUBLISHED)
  softwareId   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  software           Software      @relation(fields: [softwareId], references: [id])
  units              Unit[]
  certificates       Certificate[]
  companyAssignments CompanyCourseAssignment[]
  userAssignments    UserCourseAssignment[]
}

enum PublishState {
  HIDDEN
  VISIBLE_LOCKED
  PUBLISHED
}

model Unit {
  id        String   @id @default(uuid())
  title     String
  slug      String
  order     Int
  subtitle  String?
  duration  String?
  unitType  UnitType @default(LESSON)
  content   String?  @db.Text
  videoUrl  String?
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  guide     GuideReference?
  exercises Exercise[]
  progress  UserProgress[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  @@unique([courseId, slug])
}

enum UnitType {
  OVERVIEW
  LESSON
  EXERCISE
}

model GuideReference {
  id        String @id @default(uuid())
  zendeskId String
  title     String
  url       String
  unitId    String @unique
  unit      Unit   @relation(fields: [unitId], references: [id])
}

model Exercise {
  id          String   @id @default(uuid())
  title       String
  description String?
  htmlUrl     String?
  evdUrl      String?
  order       Int      @default(0)
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id])
  createdAt   DateTime @default(now())
}

model Certificate {
  id       String   @id @default(uuid())
  userId   String
  courseId String
  issuedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])
  @@unique([userId, courseId])
}

model UserProgress {
  id          String    @id @default(uuid())
  userId      String
  unitId      String
  completed   Boolean   @default(false)
  completedAt DateTime?
  viewedAt    DateTime?
  user        User      @relation(fields: [userId], references: [id])
  unit        Unit      @relation(fields: [unitId], references: [id])
  @@unique([userId, unitId])
  @@index([userId, completed])
}

model VideoPill {
  id          String   @id @default(uuid())
  title       String
  description String?
  youtubeId   String   @unique
  softwareId  String
  software    Software @relation(fields: [softwareId], references: [id])
  createdAt   DateTime @default(now())
}

model Event {
  id              String    @id @default(uuid())
  title           String
  description     String?   @db.Text
  eventType       EventType @default(WEBINAR)
  date            DateTime
  endDate         DateTime?
  location        String?
  maxSeats        Int?
  registrationUrl String?
  recordingUrl    String?
  published       Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum EventType {
  WORKSHOP
  WEBINAR
  LIVE_SESSION
}

model PricingPackage {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  price       String?
  priceNote   String?
  features    String[] @default([])
  highlighted Boolean  @default(false)
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
