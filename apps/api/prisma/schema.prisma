generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  name               String?
  firstName          String?
  lastName           String?
  passwordHash       String?
  role               Role                @default(USER)
  avatarUrl          String?
  lastLoginAt        DateTime?
  createdAt          DateTime            @default(now())
  deletedAt          DateTime?
  mustChangePassword Boolean             @default(false)
  progress           UserProgress[]
  certificates       Certificate[]
  membership         CompanyMembership?
  userAssignments    UserCourseAssignment[]
  announcementReads  AnnouncementRead[]
}

enum Role {
  USER
  ADMIN
  TEAM_ADMIN
}

model Company {
  id                  String    @id @default(uuid())
  name                String
  slug                String    @unique
  contractType        String?
  assistanceExpiresAt DateTime?
  notes               String?   @db.Text
  // ID dei Software (prodotti Academy) i cui contenuti sono visibili
  // all'azienda nel portale. Array vuoto = vede TUTTI i contenuti
  // (comportamento di default, compatibile con le aziende esistenti).
  // NOTA: questo filtro NON si applica alle Comunicazioni né agli Eventi.
  visibleSoftwareIds  String[]  @default([])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
  members             CompanyMembership[]
  interests           CompanyInterest[]
  courseAssignments   CompanyCourseAssignment[]
}

model CompanyMembership {
  id        String   @id @default(uuid())
  userId    String   @unique
  companyId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])
}

model CompanyInterest {
  id         String   @id @default(uuid())
  companyId  String
  softwareId String
  company    Company  @relation(fields: [companyId], references: [id])
  software   Software @relation(fields: [softwareId], references: [id])
  @@unique([companyId, softwareId])
}

model CompanyCourseAssignment {
  id         String    @id @default(uuid())
  companyId  String
  courseId   String
  accessType String    @default("ACTIVE")
  startsAt   DateTime  @default(now())
  expiresAt  DateTime?
  notes      String?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  company    Company   @relation(fields: [companyId], references: [id])
  course     Course    @relation(fields: [courseId], references: [id])
  @@unique([companyId, courseId])
}

model UserCourseAssignment {
  id         String    @id @default(uuid())
  userId     String
  courseId   String
  accessType String    @default("ACTIVE")
  startsAt   DateTime  @default(now())
  expiresAt  DateTime?
  notes      String?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id])
  course     Course    @relation(fields: [courseId], references: [id])
  @@unique([userId, courseId])
}

enum AccessType {
  ACTIVE
  LOCKED
  HIDDEN
}

// ── Comunicazioni ──────────────────────────────────────────────────────────
model Announcement {
  id          String             @id @default(uuid())
  title       String
  body        String             @db.Text
  type        AnnouncementType   @default(NEWS)
  published   Boolean            @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  isPinned    Boolean            @default(false)
  section     String             @default("NEWS")
  bannerUrl   String?
  content     String?            @db.Text
  createdBy   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  reads       AnnouncementRead[]
}

// Tracking lettura per utente — aperta = letta, non aperta = non letta
model AnnouncementRead {
  id             String       @id @default(uuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([announcementId, userId])
}

enum AnnouncementType {
  NEWS
  NEW_COURSE
  WEBINAR
  MAINTENANCE
}

model Software {
  id         String    @id @default(uuid())
  name       String
  slug       String    @unique
  tagline    String?
  color      String?
  lightColor String?
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  courses    Course[]
  interests  CompanyInterest[]
  videos     VideoPill[]
}

model Course {
  id           String      @id @default(uuid())
  title        String
  slug         String      @unique
  description  String?
  objective    String?
  level        String?
  duration     String?
  available    Boolean     @default(true)
  publishState PublishState @default(PUBLISHED)
  thumbnailUrl String?
  // Quando true, al completamento del corso l'utente riceve automaticamente
  // un Certificato (= badge nel profilo)
  issuesBadge  Boolean     @default(true)
  softwareId   String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  software           Software                  @relation(fields: [softwareId], references: [id])
  units              Unit[]
  certificates       Certificate[]
  companyAssignments CompanyCourseAssignment[]
  userAssignments    UserCourseAssignment[]
}

enum PublishState {
  HIDDEN
  VISIBLE_LOCKED
  PUBLISHED
}

model Unit {
  id        String    @id @default(uuid())
  title     String
  slug      String
  // L'order viene gestito automaticamente dal backend:
  // - OVERVIEW ha sempre order = 0
  // - le LESSON/EXERCISE ricevono order progressivo (1, 2, 3…)
  order     Int
  subtitle  String?
  // duration è la stringa formattata mostrata in UI (es. "5h", "20min", "1h 30min").
  // Le nuove unità vengono create passando durationHours e durationMinutes —
  // il backend formatta e popola questo campo.
  duration  String?
  durationHours   Int?
  durationMinutes Int?
  unitType  UnitType  @default(LESSON)
  content   String?   @db.Text
  videoUrl  String?
  courseId  String
  course    Course    @relation(fields: [courseId], references: [id])
  guides    GuideReference[]
  exercises Exercise[]
  progress  UserProgress[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  @@unique([courseId, slug])
}

enum UnitType {
  OVERVIEW
  LESSON
  EXERCISE
}

model GuideReference {
  id        String @id @default(uuid())
  zendeskId String
  title     String
  url       String
  order     Int    @default(0)
  unitId    String
  // Riferimento facoltativo al catalogo guide.
  // Quando una guida è selezionata dal catalogo, catalogId viene valorizzato
  // così l'admin modifica/cancella solo nel catalogo centralizzato.
  catalogId String?
  unit      Unit          @relation(fields: [unitId], references: [id])
  catalog   GuideCatalog? @relation(fields: [catalogId], references: [id], onDelete: SetNull)
}

// Catalogo centralizzato di guide Zendesk.
// L'admin registra un URL, il titolo viene recuperato automaticamente
// dalla pagina, e nelle unità basta selezionare dal catalogo.
model GuideCatalog {
  id         String   @id @default(uuid())
  title      String
  url        String   @unique
  zendeskId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  references GuideReference[]
}

model Exercise {
  id          String   @id @default(uuid())
  title       String
  description String?
  htmlUrl     String?
  evdUrl      String?
  order       Int      @default(0)
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id])
  createdAt   DateTime @default(now())
}

model Certificate {
  id       String   @id @default(uuid())
  userId   String
  courseId String
  issuedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])
  @@unique([userId, courseId])
}

model UserProgress {
  id          String    @id @default(uuid())
  userId      String
  unitId      String
  completed   Boolean   @default(false)
  completedAt DateTime?
  viewedAt    DateTime?
  user        User      @relation(fields: [userId], references: [id])
  unit        Unit      @relation(fields: [unitId], references: [id])
  @@unique([userId, unitId])
  @@index([userId, completed])
}

model VideoAsset {
  id        String   @id @default(uuid())
  title     String
  filename  String
  url       String
  size      Int?
  mimeType  String   @default("video/mp4")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoPill {
  id          String   @id @default(uuid())
  title       String
  description String?
  youtubeId   String   @unique
  softwareId  String
  software    Software @relation(fields: [softwareId], references: [id])
  createdAt   DateTime @default(now())
}

model Event {
  id              String    @id @default(uuid())
  title           String
  description     String?   @db.Text
  eventType       EventType @default(WEBINAR)
  date            DateTime
  endDate         DateTime?
  location        String?
  maxSeats        Int?
  registrationUrl String?
  recordingUrl    String?
  published       Boolean   @default(true)
  isRegistrable   Boolean   @default(false)
  availableSeats  Int?
  registrations   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum EventType {
  WORKSHOP
  WEBINAR
  LIVE_SESSION
}

model PricingPackage {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  price       String?
  priceNote   String?
  features    String[] @default([])
  highlighted Boolean  @default(false)
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
